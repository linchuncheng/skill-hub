# Service Dockerfile
# 基于 Eclipse Temurin JDK 21

FROM eclipse-temurin:21-jre-alpine

# 设置时区
ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 创建应用目录和日志目录
WORKDIR /app
RUN mkdir -p /app/logs

# 构建参数 - 只匹配主 jar 文件（排除 sources/javadoc）
ARG JAR_FILE=fengqun-scm-service/target/fengqun-scm-service-*.jar

# 复制 JAR 文件
COPY ${JAR_FILE} fengqun-scm-service.jar

# 使用 root 用户运行
USER root

# 暴露端口
EXPOSE 8080

# JVM 参数
ENV JAVA_OPTS="-Xms512m -Xmx1024m -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/tmp"

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --start-period=60s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/actuator/health || exit 1

# 启动命令
ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -Dspring.application.name=fengqun-scm-service -DconfigAddr=newtest-nacos.ifengqun.com:80 -DdiscoveryAddr=newtest-nacos.ifengqun.com:80 -DconfigNamespace=ai_test -Dnacos.config.server-addr=newtest-nacos.ifengqun.com:80 -Dnacos.config.namespace=ai_test -Dnacos.config.bootstrap.enable=true -Dnacos.config.data-ids=fengqun-scm-service.yml -Dnacos.config.group=DEFAULT_GROUP -Dnacos.config.type=yaml -Dspring.profiles.active=test -jar fengqun-scm-service.jar --server.port=8080"]
