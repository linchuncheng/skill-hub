{
  "viewBox": [0, 0, 900, 750],
  "title": "Coder-Report 生成核心原理",
  "subtitle": "基于 Git 提交历史的智能日报生成机制",
  "style": "rounded",
  "components": [
    {
      "id": "config_mgr",
      "label": "配置管理器",
      "subtitle": "路径读取·缓存更新",
      "xywh": [120, 100, 160, 80],
      "stroke": "#8b5cf6"
    },
    {
      "id": "user_ui",
      "label": "用户交互层",
      "subtitle": "触发·确认·反馈",
      "xywh": [370, 100, 160, 80],
      "stroke": "#10b981"
    },
    {
      "id": "overtime",
      "label": "加班申请集成",
      "subtitle": "原因拼接·自动提交",
      "xywh": [620, 100, 160, 80],
      "stroke": "#f59e0b"
    },
    {
      "id": "git_scanner",
      "label": "Git 扫描器",
      "subtitle": "并行收集·时间过滤",
      "xywh": [80, 260, 160, 80],
      "stroke": "#3b82f6"
    },
    {
      "id": "report_engine",
      "label": "日报生成引擎",
      "subtitle": "分类分析·模板渲染",
      "xywh": [350, 320, 200, 110],
      "stroke": "#3b82f6"
    },
    {
      "id": "commit_classifier",
      "label": "提交分类器",
      "subtitle": "关键词匹配·模块分组",
      "xywh": [650, 235, 160, 80],
      "stroke": "#10b981"
    },
    {
      "id": "output_formatter",
      "label": "输出格式化",
      "subtitle": "Markdown 模板",
      "xywh": [200, 500, 180, 90],
      "stroke": "#ef4444"
    },
    {
      "id": "error_handler",
      "label": "异常处理器",
      "subtitle": "无提交·配置缺失",
      "xywh": [520, 500, 180, 90],
      "stroke": "#ef4444"
    }
  ],
  "connections": [
    {
      "from": "config_mgr",
      "to": "report_engine",
      "label": "配置数据",
      "color": "#8b5cf6",
      "style": "solid",
      "animated": true
    },
    {
      "from": "user_ui",
      "to": "report_engine",
      "label": "触发指令",
      "color": "#10b981",
      "style": "solid",
      "animated": true
    },
    {
      "from": "user_ui",
      "to": "overtime",
      "label": "可选路径",
      "color": "#f59e0b",
      "style": "dashed",
      "animated": false
    },
    {
      "from": "report_engine",
      "to": "overtime",
      "label": "日报内容",
      "color": "#f59e0b",
      "style": "dashed",
      "animated": true
    },
    {
      "from": "git_scanner",
      "to": "report_engine",
      "label": "JSON 提交",
      "color": "#3b82f6",
      "style": "solid",
      "animated": true
    },
    {
      "from": "report_engine",
      "to": "commit_classifier",
      "label": "原始提交",
      "color": "#10b981",
      "style": "solid",
      "animated": true
    },
    {
      "from": "commit_classifier",
      "to": "report_engine",
      "label": "分类结果",
      "color": "#10b981",
      "style": "solid",
      "animated": true
    },
    {
      "from": "report_engine",
      "to": "output_formatter",
      "label": "结构化数据",
      "color": "#3b82f6",
      "style": "solid",
      "animated": true
    },
    {
      "from": "report_engine",
      "to": "error_handler",
      "label": "异常分支",
      "color": "#ef4444",
      "style": "dashed",
      "animated": false
    },
    {
      "from": "output_formatter",
      "to": "user_ui",
      "label": "日报展示",
      "color": "#10b981",
      "style": "dotted",
      "animated": false
    }
  ]
}
