      "type": "时标",
      "position": [0, 1],
      "attributes": ["订单号", "商品总金额", "优惠金额", "运费", "应付金额", "支付方式", "支付时间", "订单状态", "收货人", "手机号", "省", "市", "区", "详细地址", "买家备注", "发货时间", "收货时间", "取消时间", "取消原因"],
      "behaviors": ["下单", "支付", "发货", "取消"],
      "associations": ["cart", "order_item", "order_payment", "order_delivery"]
    }, {
      "model": "OrderItem",
      "name": "订单明细",
      "type": "时标",
      "position": [1, 1],
      "attributes": ["订单号", "SKU编码", "SKU名称", "规格信息", "商品图片", "单价", "数量", "小计金额", "优惠金额", "实付金额", "状态"],
      "behaviors": [],
      "associations": []
    }, {
      "model": "OrderPayment",
      "name": "支付记录",
      "type": "时标",
      "position": [1, 2],
      "attributes": ["订单号", "支付流水号", "支付方式", "支付金额", "支付状态", "支付时间", "退款金额", "退款时间"],
      "behaviors": [],
      "associations": []
    }, {
      "model": "OrderDelivery",
      "name": "订单物流",
      "type": "时标",
      "position": [2, 1],
      "attributes": ["订单号", "快递公司", "快递单号", "发货时间", "签收时间", "状态"],
      "behaviors": [],
      "associations": []
    }]
  }],
  "relations": ["用户等级->用户", "用户->收货地址", "用户->登录日志", "商品类目->商品SPU", "商品品牌->商品SPU", "商品SPU->商品SKU", "商品SKU->库存日志", "购物车->订单", "订单->订单明细", "订单->支付记录", "订单->订单物流"]
